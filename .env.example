# ------------------------------------------------------------------------------
# LLM providers
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
GIGACHAT_RQUID=
GIGACHAT_AUTH_KEY=

# ------------------------------------------------------------------------------
# LLM (OpenAI / GigaChat)
# ------------------------------------------------------------------------------
LLM_MODEL=gpt-4o-mini
GIGACHAT_MODEL=GigaChat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500

# ------------------------------------------------------------------------------
# Embeddings
# ------------------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# ------------------------------------------------------------------------------
# RAG / Chunking / Search
# ------------------------------------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=100
SEARCH_TOP_K=5
SEARCH_FETCH_K=20

# ------------------------------------------------------------------------------
# Paths
# ------------------------------------------------------------------------------
DATA_DIR=data
CACHE_DB_PATH=rag_cache.db

# ------------------------------------------------------------------------------
# Vector store
# ------------------------------------------------------------------------------
VECTOR_STORE=pinecone

# ------------------------------------------------------------------------------
# Pinecone
# ------------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=rag-demo-index
